# Application
DJANGO_SECRET_KEY=change-me-in-local-env
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# MySQL（连接已有容器，compose 不会新建 db）
# 方式 A：MySQL 容器已映射到本机 3306（Windows Docker Desktop 常用）
MYSQL_HOST=host.docker.internal
# 方式 B：backend 与 MySQL 在同一 Docker 网络时，改为 MySQL 容器名，例如：
# MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=hota_mds
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password

# 已有库且不想在容器启动时自动 migrate
SKIP_MIGRATE=1

# Services
BACKEND_PORT=8000
FRONTEND_PORT=3000
