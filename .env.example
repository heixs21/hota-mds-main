# Application
DJANGO_SECRET_KEY=change-me-in-local-env
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# MySQL
# 本地直连：127.0.0.1 或局域网 IP；Docker Compose 内 backend 服务使用 db
MYSQL_DATABASE=hota_mds
MYSQL_USER=hota_user
MYSQL_PASSWORD=hota_password
MYSQL_ROOT_PASSWORD=hota_root_password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Services
BACKEND_PORT=8000
FRONTEND_PORT=3000
